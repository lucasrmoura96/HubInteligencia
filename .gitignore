# =========================================================
# HUB Agroadvance — .gitignore
# Mantém o repo leve: só commita código + JSON gerado
# =========================================================

# Dados brutos (xlsx, csv) — NÃO commitar. São gerados pelo SharePoint
*.xlsx
*.xlsm
*.xlsb
*.csv

# Pasta de arquivamento (legado, não vai pro git)
_arquivado/

# Backups locais
**/BACKUPS/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/

# Ferramentas Claude / IDEs
.claude/
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store
desktop.ini

# Logs e temporários
*.log
*.tmp
~$*

# Arquivos sensíveis (não deve ter, mas por garantia)
.env
*.key
credentials.json

# =========================================================
# SEGURANÇA — dados em texto puro NÃO vão pro deploy
# Só o arquivo CIFRADO (performance_mkt_enc.js) é publicado.
# =========================================================
# Senhas/usuários — JAMAIS commitar (só os .example vão pro git)
senhas.local.json
usuarios.local.json

# Dados em texto puro (entrada da cifragem) — ficam só na máquina local
hub/dados/performance_mkt.json
hub/dados/performance_mkt.js
# (ultima_atualizacao.json continua público — só tem data, nada sensível)
